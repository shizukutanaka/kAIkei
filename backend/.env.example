DATABASE_URL=postgresql+asyncpg://kaikei:kaikei_dev@localhost:5432/kaikei
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local LLM (Ollama / vLLM / llama.cpp / LM Studio)
# Example: Ollama → http://localhost:11434/v1
# Example: vLLM   → http://localhost:8000/v1
# Example: LM Studio → http://localhost:1234/v1
LOCAL_LLM_ENDPOINT=
LOCAL_LLM_MODEL=llama3.2:7b
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_TIMEOUT=60.0

# Task routing: prefer free/local providers for light tasks
AI_PREFER_FREE=true

S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=kaikei-documents

LOG_LEVEL=INFO
